generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           BigInt    @id @default(autoincrement())
  fullName     String    @db.VarChar(255)
  email        String    @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  phoneNumber  String?   @db.VarChar(20)
  schoolId     BigInt
  roleId       BigInt
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id])
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  rolePermissionsUpdated  RolePermission[]    @relation("UpdatedByUser")
  enrollments             StudentEnrollment[] @relation("StudentEnrollments")
  teacherAssignments      TeacherAssignment[] @relation("TeacherAssignments")
  classTeacherAssignments ClassTeacher[]      @relation("ClassTeacherAssignments")
  studentAttendance       StudentAttendance[] @relation("StudentAttendance")
  teacherAttendance       TeacherAttendance[] @relation("TeacherAttendance")

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([roleId])
}

model School {
  id          BigInt      @id @default(autoincrement())
  name        String      @db.VarChar(255)
  type        SchoolType
  board       SchoolBoard
  city        String      @db.VarChar(100)
  state       String      @db.VarChar(100)
  website     String?     @db.VarChar(255)
  udiseNumber String      @unique @db.VarChar(50)
  isVerified  Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  users                   User[]
  roles                   Role[]
  classes                 Class[]
  subjects                Subject[]
  academicYears           AcademicYear[]
  enrollments             StudentEnrollment[]
  teacherAssignments      TeacherAssignment[]
  classTeacherAssignments ClassTeacher[]
  studentAttendance       StudentAttendance[]
  teacherAttendance       TeacherAttendance[]
}

model Role {
  id         BigInt     @id @default(autoincrement())
  schoolId   BigInt
  name       String     @db.VarChar(100)
  portalType PortalType
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  users       User[]
  permissions RolePermission[]

  @@unique([schoolId, name, portalType])
  @@index([schoolId])
}

model Permission {
  id         BigInt     @id @default(autoincrement())
  module     String     @db.VarChar(100)
  feature    String     @db.VarChar(100)
  portalType PortalType
  label      String?    @db.VarChar(255)
  order      Int        @default(0)
  createdAt  DateTime   @default(now())

  rolePermissions RolePermission[]

  @@unique([module, feature, portalType])
  @@index([module])
  @@index([portalType])
}

model RolePermission {
  roleId       BigInt
  permissionId BigInt
  canRead      Boolean  @default(false)
  canCreate    Boolean  @default(false)
  canUpdate    Boolean  @default(false)
  canDelete    Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  updatedBy    BigInt?

  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  updatedByUser User?      @relation("UpdatedByUser", fields: [updatedBy], references: [id])

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/// A school "session" e.g. "2025-26". Enrollments, assignments, and
/// attendance are all scoped to a year so historical data survives
/// year-over-year rollover. Exactly one year per school should have
/// isActive = true at a time (enforce in application logic).
model AcademicYear {
  id        BigInt    @id @default(autoincrement())
  schoolId  BigInt
  label     String    @db.VarChar(20) // e.g. "2025-26"
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  isActive  Boolean   @default(false)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  enrollments        StudentEnrollment[]
  teacherAssignments TeacherAssignment[]
  classTeachers      ClassTeacher[]
  studentAttendance  StudentAttendance[]
  teacherAttendance  TeacherAttendance[]

  @@unique([schoolId, label])
  @@index([schoolId])
  @@index([schoolId, isActive])
}

/// Class/Section are year-agnostic containers ("Class 5" persists as a
/// concept across years). Soft-deleted rather than removed so historical
/// enrollment/attendance rows referencing them stay resolvable.
model Class {
  id        BigInt    @id @default(autoincrement())
  schoolId  BigInt
  name      String    @db.VarChar(50)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sections  Section[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  enrollments        StudentEnrollment[]
  teacherAssignments TeacherAssignment[]
  classTeachers      ClassTeacher[]
  studentAttendance  StudentAttendance[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Section {
  id        BigInt    @id @default(autoincrement())
  classId   BigInt
  name      String    @db.VarChar(20)
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  enrollments        StudentEnrollment[]
  teacherAssignments TeacherAssignment[]
  classTeacher       ClassTeacher[]
  studentAttendance  StudentAttendance[]

  @@unique([classId, name])
  @@index([classId])
}

model Subject {
  id        BigInt   @id @default(autoincrement())
  schoolId  BigInt
  name      String   @db.VarChar(100)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherAssignments TeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model StudentEnrollment {
  id             BigInt   @id @default(autoincrement())
  studentId      BigInt
  classId        BigInt
  sectionId      BigInt
  schoolId       BigInt
  academicYearId BigInt
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      User         @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  // A student can only have one enrollment per class per year (covers
  // re-enrollment/repeat scenarios across different years cleanly).
  @@unique([studentId, classId, academicYearId])
  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@index([studentId])
  @@index([academicYearId])
}

model TeacherAssignment {
  id             BigInt   @id @default(autoincrement())
  teacherId      BigInt
  classId        BigInt
  sectionId      BigInt
  subjectId      BigInt
  schoolId       BigInt
  academicYearId BigInt
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher      User         @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@unique([teacherId, classId, sectionId, subjectId, academicYearId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([academicYearId])
}

/// Homeroom / in-charge teacher for a section — no subject involved.
/// One class teacher per section per year, enforced via
/// @@unique([sectionId, academicYearId]).
model ClassTeacher {
  id             BigInt   @id @default(autoincrement())
  teacherId      BigInt
  classId        BigInt
  sectionId      BigInt
  schoolId       BigInt
  academicYearId BigInt
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher      User         @relation("ClassTeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@unique([sectionId, academicYearId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([academicYearId])
}

model StudentAttendance {
  id             BigInt           @id @default(autoincrement())
  studentId      BigInt
  classId        BigInt
  sectionId      BigInt
  schoolId       BigInt
  academicYearId BigInt
  date           DateTime         @db.Date
  status         AttendanceStatus
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student      User         @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  // Restrict, not Cascade: a class/section can't be deleted while
  // attendance history references it — forces soft-delete instead.
  class        Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([classId, sectionId, date])
  @@index([studentId])
  @@index([academicYearId])
}

model TeacherAttendance {
  id             BigInt           @id @default(autoincrement())
  teacherId      BigInt
  schoolId       BigInt
  academicYearId BigInt
  date           DateTime         @db.Date
  status         AttendanceStatus
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  teacher      User         @relation("TeacherAttendance", fields: [teacherId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@unique([teacherId, date])
  @@index([schoolId, date])
  @@index([academicYearId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
}

enum PortalType {
  ADMIN
  STAFF
  TEACHER
  STUDENT
}

enum SchoolType {
  PUBLIC
  PRIVATE
  OTHER
}

enum SchoolBoard {
  CBSE
  ICSE
  STATE
  OTHER
}